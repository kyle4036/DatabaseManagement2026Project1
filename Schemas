PHYSICAL LAYER

Airlines(
    lineID: char(2),
    name: char(20),
    Primary key(lineID)
)

Airports(
    portID: char(3),
    name: char(20),
    Primary key(portID)
)

Aircrafts(
    craftID: int,
    lineID: char(2),
    portID: char(3),
    capacity: int,
    Foreign key(lineID) references Airlines,
    Foreign key(portID) references Airports,
    Primary key (craftID)
)

AirlineOperatesIn(
    lineID: char(2),
    portID: char(3),
    Foreign key(lineID) references Airlines,
    Foreign key(portID) references Airports,
    Primary key(lineID, portID)
)

SCHEDULING LAYER

Flights(
    flightNumber: char(5),
    lineID: char(2),
    departure_portID: char(3),
    destination_portID: char(3),
    departureTime: time,
    arrivalTime: time,
    flightType: char(20),
    daysRunning: char(7),
    seatsTaken: int,
    craftID: int,
    Foreign key(lineID) references Airlines,
    Foreign key(departure_portID) references Airports,
    Foreign key(destination_portID) references Airports,
    Foreign key(craftID) references Aircrafts,
    Primary key(flightNumber, lineID)
)

Tickets(
    ticketNumber: int,
    customerID: int,
    purchaseTime: datetime,
    bookingfee: decimal(10, 2),
    fareCost: decimal(10, 2),
    tripType: char(10),
    status: char(10),
    Foreign key(customerID) references Customers,
    Primary key(ticketNumber)
)

FlightTicket(
    ticketNumber: int,
    flightNumber: char(5),
    lineID: char(2),
    legOrder: int,
    departureDate: date,
    seatNumber: char(5),
    ticketClass: char(10),
    mealOrder: char(50),
    Foreign key(ticketNumber) references Tickets,
    Foreign key(flightNumber, lineID) references Flights,
    Primary key(ticketNumber, legOrder)
)

SERVICE LAYER

Customers(
    customerID: int,
    firstName: char(20),
    lastName: char(20),
    email: char(50),
    phoneNumber: char(12),
    Primary key(customerID)
)

Employees(
    employeeID: int,
    firstName: char(20),
    lastName: char(20),
    role: char(20),
    Primary key(employeeID)
)

CustomerRepresentative(
    employeeID: int,
    Foreign key(employeeID) references Employees,
    Primary key(employeeID)
)

WaitingList(
    customerID: int,
    flightNumber: char(5),
    requestTime datetime,
    Foreign key(customerID) references Customers,
    Foreign key(flightNumber) references Flights
)
